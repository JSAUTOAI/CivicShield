# =============================================================================
# CIVICSHIELD ENVIRONMENT CONFIGURATION (TEMPLATE)
# =============================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it contains live secrets.
# Keep a backup of your real `.env` in an encrypted password manager
# (Bitwarden Secure Note or 1Password). See PERSONAL.md for the full
# backup + rebuild procedure.
# =============================================================================

# --- DATABASE (REQUIRED) ---
# Railway PostgreSQL connection string.
# Dashboard: https://railway.app → your project → PostgreSQL → Connect
DATABASE_URL=""

# --- AUTH (REQUIRED) ---
# NEXTAUTH_URL: your deployment URL. For local dev use http://localhost:3001
NEXTAUTH_URL="http://localhost:3001"
# Generate a secret locally: `openssl rand -base64 32`
NEXTAUTH_SECRET=""

# --- AI ANALYSIS (OPTIONAL — mock fallback works without it) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# --- EMAIL (REQUIRED for complaint delivery + auth emails) ---
# https://resend.com/api-keys
# The civicshield.co.uk domain must be verified in the Resend dashboard.
RESEND_API_KEY=""
EMAIL_FROM="CivicShield <complaints@civicshield.co.uk>"
EMAIL_NOREPLY="CivicShield <noreply@civicshield.co.uk>"
# Inbound email domain for reply tracking (must match Resend inbound config)
EMAIL_INBOUND_DOMAIN="civicshield.co.uk"

# --- STRIPE (REQUIRED for subscriptions) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Create monthly Products/Prices in Stripe, then paste the price IDs below.
STRIPE_BASIC_MONTHLY_PRICE_ID=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_AGENCY_MONTHLY_PRICE_ID=""

# --- AWS S3 (REQUIRED for file uploads / evidence) ---
# See S3-SETUP-GUIDE.md for IAM + bucket creation steps.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-2"
AWS_S3_BUCKET="civicshield-evidence"
